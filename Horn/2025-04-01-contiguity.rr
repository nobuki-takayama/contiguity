/*
  中山methodで GB へ変換する行列を求める.
  2025.03.18
*/
/* 
   T_matrix[0]=T_matrix[1]*T_matrix[2] 
   T_matrix[0]-T_matrix[1]*T_matrix[2]; //should be 0
*/
def get_transformation_matrix(F,V,Ord) {
  if (type(getopt(weyl))>0) {
    Weyl=1;
  }else{
    Weyl=0;
  }
  Check=0;
  // Check=1; //for debug
  MM=length(F);
  F2=[];
  for (I=0; I<MM; I++) {
    FF=newvect(MM+1); FF[0]=F[I];
    FF[I+1]=1;
    F2=cons(vtol(FF),F2);
  }
  F2=reverse(F2);

  if (Weyl) {
    G=nd_weyl_gr(F,V,0,Ord);
    G2=nd_weyl_gr(F2,V,0,[1,Ord]);
  }else{
    G=nd_gr(F,V,0,Ord);
    G2=nd_gr(F2,V,0,[1,Ord]);
  }
  Debug_G_G2=[G,G2];
  T_matrix=transformation_as_matrix(F,G2,V,Check | option_list=getopt());
  return T_matrix; 
}
def transformation_as_matrix(F,G2,V,Check) {
  if (type(getopt(weyl))>0) Weyl=1;else Weyl=0;
  if (Weyl) {
    VV=newvect(length(V)/2);
    for (I=0; I<length(VV); I++) VV[I]=V[I];
    VV=vtol(VV);
  }
  Mat=[]; GG=[];
  for (I=0; I<length(G2); I++) {
    if (G2[I][0] != 0) {
      if (Debug) printf("G[%a]=%a\n",I,G2[I]);
      S=G2[I][0];
      MatI=newvect(length(G2[I])-1);
      for (J=1; J<length(G2[I]); J++) {
        MatI[J-1]=G2[I][J];
        if (Check) {
          if (Weyl) {
            S=S-poly_dmul(G2[I][J],F[J-1],VV);
          }else{
            S=S-G2[I][J]*F[J-1];
          }
        }
      }
      Mat=cons(vtol(MatI),Mat);
      GG=cons(G2[I][0],GG);
    }
    if (Check) {
      if (S != 0) {
        print("transformation_as_matrix, check fails."); debug();
        return 0;
      }else{
	printf("I=%a, check passed.\n",I);
      }
    }
  }
  Mat=reverse(Mat);
  GG=reverse(GG);
  T_matrix=map(matrix_list_to_matrix,[GG,Mat,F]);
  return T_matrix;
}

