def taka_poly_coefficient_list(F,V) {
  if (type(F) > 3) return map(taka_poly_coefficient_list,F,V);
  if (type(F)==3) {
    Dn=dn(F);
    if (length(base_intersection(vars(Dn),V))>0) error("rational input");
    F=nm(F);
  }else Dn=1;
  G=dp_ptod(F,V);
  Clist=[]; MonList=[];
  while (G!=0) {
    Clist=cons(red(dp_hc(G)/Dn),Clist);
    MonList=cons(dp_dtop(dp_ht(G),V),MonList);
    G=dp_rest(G);
  }
  return [Clist,MonList];
}

def taka_poly_coefficient_list0(F,V) {
  if (type(F)>3) return map(taka_poly_coefficient_list0,F,V);
  return taka_poly_coefficient_list(F,V)[0];
}
