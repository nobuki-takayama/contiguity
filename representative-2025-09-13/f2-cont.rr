def contiguity2_(P1,P2) {
  Sol=[u001+u002*x+u003*y+u004*x^2+u005*x*y+u006*y^2
       +u007*x^3+u008*x^2*y+u009*x*y^2+u0010*y^3
       +u0011*x^4+u0012*x^3*y+u0013*x^2*y^2+u0014*x*y^3+u0015*y^4,
       u101+u102*x+u103*y+u104*x^2+u105*x*y+u106*y^2
       +u107*x^3+u108*x^2*y+u109*x*y^2+u1010*y^3
       +u1011*x^4+u1012*x^3*y+u1013*x^2*y^2+u1014*x*y^3+u1015*y^4,
       u011+u012*x+u013*y+u014*x^2+u015*x*y+u016*y^2
       +u017*x^3+u018*x^2*y+u019*x*y^2+u0110*y^3 
       +u0111*x^4+u0112*x^3*y+u0113*x^2*y^2+u0114*x*y^3+u0115*y^4,
       u021+u022*x+u023*y+u024*x^2+u025*x*y+u026*y^2
       +u027*x^3+u028*x^2*y+u029*x*y^2+u0210*y^3 
       +u0211*x^4+u0212*x^3*y+u0213*x^2*y^2+u0214*x*y^3+u0215*y^4,
       u111+u112*x+u113*y+u114*x^2+u115*x*y+u116*y^2
       +u117*x^3+u118*x^2*y+u119*x*y^2+u1110*y^3
       +u1111*x^4+u1112*x^3*y+u1113*x^2*y^2+u1114*x*y^3+u1115*y^4
      ];
  NT_sol=Sol;
  U=reverse(base_set_minus(vars(Sol),[x,y]));
  print(U);
  T=my_geneq(P1,P2 | sol=Sol);
  /*
  T=geneq(P1,P2 | sol=Sol);
  */
  NT_1=T;
  T1=base_flatten(taka_poly_coefficient_list0(T,[x,y]))$
  NT_2=T1;
  Rule=poly_solve_linear(T1,U);
  if (Rule == []) error("No solution.");
  return [base_replace(Sol,Rule),Rule];
}

def contiguity3(P1,P2) {
	if (type(getopt(base)) == -1) {
  		Base = [1,dx,dy,dy^2,dx*dy];
	} else {
		Base = getopt(base);
  	}
	if (type(getopt(deg)) == -1) {
  		Deg = 3;	
	} else {
		Deg = getopt(deg);
  	}
  	Sol = gen_sol(Base, Deg);

  NT_sol=Sol;
  U=reverse(base_set_minus(vars(Sol),[x,y]));
  // print(U);
  T=my_geneq(P1,P2 | sol=Sol);
  /*
  T=geneq(P1,P2 | sol=Sol);
  */
  NT_1=T;
  T1=base_flatten(taka_poly_coefficient_list0(T,[x,y]))$
  NT_2=T1;
  // print("poly_solve_linear"); print("T1:"); print(T1); print("U:"); print(U);
  Rule=poly_solve_linear(T1,U);
  // print("Rule:"); print(Rule);
  if (Rule == []) error("No solution.");
  return [base_replace(Sol,Rule),Rule,U];
}


/* 
I2(ParamPlus) H(Param) \subset I2(Param)
I2(Param) B(ParamPlus) \subset I2(ParamPlus)
となる H(Param), B(ParamPlus) を返す
B(ParamPlus) H(Param) mod I2(Param) も返す 
e.g. 
find_cont([a,b,bb,c+1,cc], [a,b,bb,c,cc])
--> c についての上昇作用素 H(c), 
    c についての下降作用素 B(c+1) 
    B(c+1) H(c) mod I2(c) の結果を返す
*/
def find_cont(ParamPlus, Param)
{
	if (type(getopt(base)) == -1) {
  		Base = [1,dx,dy,dy^2,dx*dy];
	} else {
		Base = getopt(base);
  	}
	if (type(getopt(deg)) == -1) {
  		Deg = 2;	
	} else {
		Deg = getopt(deg);
  	}
	//print("Base:", 0); print(Base);
	//print("Deg:", 0); print(Deg);

  	Sol = gen_sol(Base, Deg);
	L1 = contiguity3(ParamPlus, Param|base=Base, deg=Deg);
	VL_U = L1[2];
	VL_V = map(change_var_name, VL_U, v);
	RuleUV = assoc(VL_U, VL_V);
	L2 = contiguity3(Param, ParamPlus|base=Base, deg=Deg);
	//print(L1);
	//print(L2);

	H = red(to_op(L1[0]));
	BP = red(to_op(L2[0]));
	BP = base_replace(BP, RuleUV);
	NH = nm(H);
	NBP = nm(BP); 
	print("H:", 0); print(H);
	print("BP:", 0); print(BP);

	yang.define_ring(["partial", [x,y]]);
	Id = appell_f2(|param=Param); 
	IdP = appell_f2(|param=ParamPlus); 
	Id = map(dp_ptod, Id, [dx,dy]);
	IdP = map(dp_ptod, IdP, [dx,dy]);
	// print("Id:"); print(Id);
	G = yang.buchberger(Id);
	// print("IdP:"); print(IdP);
	GP = yang.buchberger(IdP);

	// print("B(ParamPlus)H(Param) mod I2(Param)");
	BH = dmult2(NBP, NH);
	BH = dp_ptod(BH, [dx,dy]);
	R = yang.reduction(BH, G);
	// print("R:", 0); print(R);
	// print("fctr(R[0]):"); print(fctr(dp_hc(R[0])));

	// print("H(Param)B(ParamPlus) mod I2(ParamPlus)");
	HB = dmult2(NH, NBP);
	HB = dp_ptod(HB, [dx,dy]);
	RR = yang.reduction(HB, GP);
	// print("RR:", 0); print(RR);
	// print("fctr(RR[0]):"); print(fctr(dp_hc(RR[0])));

	/* uv_cond.rr の extern 変数 */
	NT_UL = VL_U;
	NT_VL = VL_V;
	Rules = get_uv_rules(R[0]);
	HOP = base_replace(H, Rules[0]);
	//HOP = base_replace(HOP, Rules[1]);
	Rules2 = get_uv_rules(RR[0]);
	BPOP = base_replace(BP, Rules2[0]);
	//BPOP = base_replace(BPOP, Rules2[1]);
	return [HOP, BPOP, dp_hc(R[0])];
}

/*******************************************************
find_cont_recursive  
 *******************************************************/

RDeg = 3$  /* find_cont に渡す option  */

/* 未定係数の u***, v*** に 1 を代入して u***, v*** を消す */
def find_cont_auto(ParamPlus, Param)
{
	extern RDeg;
	T = find_cont(ParamPlus, Param|deg=RDeg);

	H = T[0];
	VL = vars(H);
	UV = pick_uv_vars(VL);
	Rule1 = l_compo(UV, l_const(length(UV), 1)); /* u***, v*** に 1 を代入するルール */
	H = base_replace(H, Rule1);

 	B = T[1];
	VL = vars(B);
	UV = pick_uv_vars(VL);
	Rule2 = l_compo(UV, l_const(length(UV), 1)); /* u***, v*** に 1 を代入するルール */
	B = base_replace(B, Rule2);

	Cond = T[2];

	//VL = vars(Cond);
	//UV = pick_uv_vars(VL);
	//Rule = l_compo(UV, l_const(length(UV), 1)); /* u***, v*** に 1 を代入するルール */
	//Cond = base_replace(Cond, Rule);

	Rule = append(Rule1, Rule2);
	Cond = base_replace(Cond, Rule);
	if (Cond == 0) 
		print("Cond = 0");
	return [H, B, Cond];
}

def test_find_cont_auto()
{
	return find_cont_auto([a,b,bb,c+1,cc], [a,b,bb,c,cc]);
}

def test_find_cont_auto2()
{
	find_cont_auto([a,b,-1,c+1,cc],[a,b,-1,c,cc]);
}

def space(N)
{
	S = "";
	for (I = 0; I < N; I++)
		S += " ";
	return S;
}

Depth = 0$ /* 表示用. 再帰の深さを保存 */

/*
find_cont_auto を再帰的に呼び出しては実行し, パラメータの変数を減らしていく 
c+1, c の隣接関係式に限定.
*/
def find_cont_recursive(ParamPlus, Param)
{
	extern Depth;
	Depth++;
	print(space(6 * Depth), 0);
	print("(" + rtostr(Depth) + ")find_cont_recursive(" + rtostr(ParamPlus) + "," + rtostr(Param) +") {");

	ord([a,b,bb,cc,c]); /* 優先されて消されていくパラメータの順序 */	
	L = find_cont_auto(ParamPlus, Param);
	H = L[0];
	B = L[1];
	Cond = L[2];
	Factors = fctr(Cond);
	// print(space(6 * (Depth+1)), 0);
	// print("Factors:", 0); print(Factors);
	Factors = remove_uv_factors(Factors); // u***, v*** のみの因子を除く. 定数部分も除く 
	print(space(6 * (Depth+1)), 0);
	print("Factors:", 0); print(Factors);
	print(space(6 * (Depth+1)), 0);
	print("H=", 0); print(H, 0); print(";");
	print(space(6 * (Depth+1)), 0);
	print("B=", 0); print(B, 0); print(";");
	for (I = 0; I < length(Factors); I++) {
		T = Factors[I][0];

		/* c のみの条件はスキップ */
		if (vars(T) == [c])
			continue;

		Rule = [eq_to_rule(T)];
		print(space(6 * (Depth+1)), 0);
		print("Rule:", 0); print(Rule);
		if (Rule == [[]])
			continue;
		Orig = base_replace(Param, Rule);

		/* c+1, c の隣接関係式に限定 */
		Plus = base_replace(Orig, [[c,c+1]]);

		// print([Plus, Orig]);
		find_cont_recursive(Plus, Orig);
	}

	print(space(6 * Depth), 0);
	print("}"); print("");
	Depth--;
}

def test_find_cont_recursive()
{
	return find_cont_recursive([a,b,bb,c+1,cc], [a,b,bb,c,cc]);
}

/* 1 次式 Eq = 0 から変数を消去する関係式を作成 */
/* e.g. Eq = a + b + 1 ---> [a,-b-1]            */
def eq_to_rule(Eq)
{
	if (!is_linear(Eq)) {
		print("Eq is not linear.");
		return [];
	}
	VL = vars(Eq);
	V = VL[0];
	C = coef(Eq, 1, V);
	RHS = -(Eq - C*V)/C;
	return [V, RHS];
}

def test_eq_to_rule()
{
	print(eq_to_rule(x-2*y-1));
	print(eq_to_rule(3*x+2*y+1));
	print(eq_to_rule(5*x+2*y+3*z-4));
	print(eq_to_rule(5*x-4));
	print(eq_to_rule(x^2+x+1));
}

/* 1 次式かどうか */
def is_linear(Eq)
{
	VL = vars(Eq);
	DP = dp_ptod(Eq, VL);

	/* 定数 */
	if (DP == 0) 
		return 0;
	if (VL == [])
		return 0;

	while (DP != 0) {
		T = dp_etov(DP);
		Deg = l_sum(T);
		if (Deg > 1)
			return 0;
		DP = dp_rest(DP);
	}
	return 1;
}

def test_is_linear()
{
	print(is_linear(x+y+1));
	print(is_linear(1));
	print(is_linear(x^2+y^2+1));
	print(is_linear(x*y+x+y+1));
}

/* リストの各要素の和 */
def l_sum(L)
{
	S = 0;
	for (I = 0; I < length(L); I++)
		S += L[I];	
	return S;
}

/* 変数リスト VL から u***, v*** を取り出し */
def pick_uv_vars(VL)
{
	UV = [];
	for (I = 0; I < length(VL); I++) {
		FirstC = sub_str(rtostr(VL[I]), 0, 0);
		if (FirstC == "u" || FirstC  == "v") 
			UV = cons(VL[I], UV);
	}
	return UV;
}

def test_pick_uv_vars()
{
	L = [a,b,c,aa,bb,u113,v112,v013];
	return pick_uv_vars(L);
}

/* L : fctr の結果                                                    */
/* fctr の各要素で, u***, v*** だけからなるものを消去. 定数部分も消去 */
/* e.g. [[-1,1],[u113,1],[bb+1,1],[b-c,1],[a-c,1],[a-cc-c+1,1]]       */
/*      ---> [[bb+1,1],[b-c,1],[a-c,1],[a-cc-c+1,1]]                  */
def remove_uv_factors(L)
{
	VL = vars(L);	
	UV = pick_uv_vars(VL);
	LL = [];
	for (I = 0; I < length(L); I++) {
		T = L[I][0];
		if (is_subset(vars(T), UV)) {
			/* T は u***, v*** だけからなる因子 */
			/* 何もせず. */
		} else {
			LL = cons(L[I], LL);
		}
	}
	return reverse(LL);
}

def test_remove_uv_factors()
{
	L = [[-1,1],[u113,1],[bb+1,1],[b-c,1],[a-c,1],[a-cc-c+1,1]];
	return remove_uv_factors(L);
}

/* from util.rr */
/* "E \in L" true or false ? */
def is_element(E, L)
{
	Len = length(L);
	for (I = 0; I < Len; I++) {
		if (E == L[I])
			return 1;
	}
	return 0;
}

/* "L \subset VL" true or false ? */
def is_subset(L, VL)
{
	Len = length(L);
	Vlen = length(VL);
	for (I = 0; I < Len; I++) {
		for (J = 0; J < Vlen; J++) {
			if (L[I] == VL[J])
				break;
		}
		if (J == Vlen)
			return 0;
	}
	return 1;
}


/* 
l_compo([x,y,z], [1,2,3]) --> [[x,1],[y,2],[z,3]]
*/
def l_compo(L1, L2)
{
	L = [];
	N = length(L1);
	if (length(L2) < length(L1)) 
		N = length(L2);
	for (I = 0; I < N; I++) 
		L = cons([L1[I], L2[I]], L);
	return reverse(L);	
}

def test_l_compo()
{
	return l_compo([x,y,z], [1,2,3]);
}

/* Const が N 個のリストを作成 */
def l_const(N, Const)
{
	L = [];
	for (I = 0; I < N; I++)
		L = cons(Const, L);
	return L;
}

