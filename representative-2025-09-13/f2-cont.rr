def func_v_rule(Sym,Deg) {
  TmpFile="tmp_rule0.txt";
  Com=sprintf("./func_v_rule %a %a >%a",Sym,Deg,TmpFile);
//  print(Com);
  shell(Com);
  S=util_read_file_as_a_string(TmpFile);
  return S;
}

//T=func_v_rule(q00,2);
def func_v_rule2(Sym,Deg,FFF) {
  R=eval_str(func_v_rule(Sym,Deg));
  return R;
}

//Lplus=[a+1,b1,b2,c1,c2], L=[a,b1,b2,c1,c2]
/*
I2(Lplus) Q \in I2(L) となる Q の 1, dx, dy, dy^2, dx*dy の係数を返す
*/
def my_geneq(Lplus,L) {
  if (type(getopt(sol))>0) {
    Sol=getopt(sol);
    Q00=Sol[0]; Q10=Sol[1]; Q01=Sol[2]; Q02=Sol[3]; Q11=Sol[4];
  }else {
    Sol=0;
    Q00=a; Q10=x; Q01=y; Q02=0; Q11=0;
  }
  Rule0=[[x1,x],[x2,y],[dx1,dx],[dx2,dy]];
  F1plus=base_replace(appellF2(Lplus)[0],Rule0);
  F1=base_replace(appellF2(L)[0],Rule0);
  Q=q00(x,y)+q10(x,y)*dx+q01(x,y)*dy+q02(x,y)*dy^2+q11(x,y)*dx*dy;
  Ops=map(dmult2,F1plus,Q);
  R1=my_func_v_rule2(q00(x,y),2,Q00); R2=my_func_v_rule2(q10(x,y),2,Q10);
  R3=my_func_v_rule2(q01(x,y),2,Q01); R4=my_func_v_rule2(q02(x,y),2,Q02);
  R5=my_func_v_rule2(q11(x,y),2,Q11); 
  /*
  R1=func_v_rule2(q00,2,Q00); R2=func_v_rule2(q10,2,Q10);
  R3=func_v_rule2(q01,2,Q01); R4=func_v_rule2(q02,2,Q02);
  R5=func_v_rule2(q11,2,Q11); 
  */
  Rule=append_n([R1[0],R2[0],R3[0],R4[0],R5[0]]);
  Ops2=base_replace(Ops,Rule);  // I(a+1)*Q
  yang.define_ring(["partial",[x,y]]);
  F=map(dp_ptod,F1,[dx,dy]);
  G=yang.buchberger(F);
  // print(yang.stdmon(G)); // [dy^2,dx,dy,1]
  Ops3=map(dp_ptod,Ops2,[dx,dy]);
  Ops4=map(yang.reduction,Ops3,G);
  Ops4=map(my_base_ith,Ops4,0);
  /*
  Ops4=map(base_ith,Ops4,0);
  */

  Check=0; 
  // 下記の generic な場合の解は x*dx+y*dy+a. Check=1でこれが満たしているか調べる.
  if (Check || Sol){
    RuleSol=append_n([R1[3],R2[3],R3[3],R4[3],R5[3]]);
    NT_1=RuleSol;
    Ops4=base_replace(Ops4,RuleSol);
    if (Check) printf("Check=%a\n",Ops4);
  }

  Rule_to_op=append_n([R1[1],R2[1],R3[1],R4[1],R5[1]]);
  // collect all coefs
  C=[];
  for (I=0; I<length(Ops4); I++) {
    F=Ops4[I];
    while (F!=0) {
      C=cons(dp_hc(F),C);
      F=dp_rest(F);
    }
  }
  return [C, base_replace(C,Rule_to_op)];
  /* [変数形式, 関数形式] */
}
//T=geneq([a+1,b1,b2,c1,c2],[a,b1,b2,c1,c2]);

//Lplus=[a+1,b1,b2,c1,c2], L=[a,b1,b2,c1,c2]
def geneq(Lplus,L) {
  if (type(getopt(sol))>0) {
    Sol=getopt(sol);
    Q00=Sol[0]; Q10=Sol[1]; Q01=Sol[2]; Q02=Sol[3]; Q11=Sol[4];
  }else {
    Sol=0;
    Q00=a; Q10=x; Q01=y; Q02=0; Q11=0;
  }
  Rule0=[[x1,x],[x2,y],[dx1,dx],[dx2,dy]];
  F1plus=base_replace(appellF2(Lplus)[0],Rule0);
  F1=base_replace(appellF2(L)[0],Rule0);
  Q=q00(x,y)+q10(x,y)*dx+q01(x,y)*dy+q02(x,y)*dy^2+q11(x,y)*dx*dy;
  Ops=map(dmult2,F1plus,Q);
  R1=func_v_rule2(q00,2,Q00); R2=func_v_rule2(q10,2,Q10);
  R3=func_v_rule2(q01,2,Q01); R4=func_v_rule2(q02,2,Q02);
  R5=func_v_rule2(q11,2,Q11); 
  Rule=append_n([R1[0],R2[0],R3[0],R4[0],R5[0]]);
  Ops2=base_replace(Ops,Rule);  // I(a+1)*Q
  yang.define_ring(["partial",[x,y]]);
  F=map(dp_ptod,F1,[dx,dy]);
  G=yang.buchberger(F);
  print(yang.stdmon(G)); // [dy^2,dx,dy,1]
  Ops3=map(dp_ptod,Ops2,[dx,dy]);
  Ops4=map(yang.reduction,Ops3,G);
  Ops4=map(base_ith,Ops4,0);

  Check=0; 
  // 下記の generic な場合の解は x*dx+y*dy+a. Check=1でこれが満たしているか調べる.
  if (Check || Sol){
    RuleSol=append_n([R1[3],R2[3],R3[3],R4[3],R5[3]]);
    NT_1=RuleSol;
    Ops4=base_replace(Ops4,RuleSol);
    if (Check) printf("Check=%a\n",Ops4);
  }

  Rule_to_op=append_n([R1[1],R2[1],R3[1],R4[1],R5[1]]);
  // collect all coefs
  C=[];
  for (I=0; I<length(Ops4); I++) {
    F=Ops4[I];
    while (F!=0) {
      C=cons(dp_hc(F),C);
      F=dp_rest(F);
    }
  }
  return [C, base_replace(C,Rule_to_op)];
  /* [変数形式, 関数形式] */
}
