/* u, v 変数のリスト */
/* NT_UL, NT_VL は多くとっても問題ない */
NT_UL=[u001,u002,u003,u004]$
NT_VL=[v001,v002,v003,v004]$
/* パラメータのリスト */
NT_Param=[a,b,bb,c,cc]$

/*
F の因子について, 変数 NT_Param を含まないものを取り出し Type をひく. 
それらを要素とするリストを返す.
e.g. 
[2769] F;
((u001-u002)*a+(-u001+u002)*b)*x+(-u001+u002)*a+(u001-u002)*b
[2770] fctr(F);
[[1,1],[u001-u002,1],[a-b,1],[x-1,1]]
[2771] get_uv_factors(F, 0);
[x-1,u001-u002]
[2772] get_uv_factors(F, 1);
[x-2,u001-u002-1]
*/
def get_uv_factors(F,Type) {
  L=fctr(F);
  Ans=[];
  for (I=0; I<length(L); I++) {
    E=L[I][0];
    if (vars(E) == []) continue;
    if (base_set_intersection(NT_Param,vars(E)) == []) {
      Ans=cons(E-Type,Ans);
    }
  }
  return Ans;
}

def get_uv_0factors(F) {
  return get_uv_factors(F,0);
}

def get_uv_1factors(F) {
  return get_uv_factors(F,1);
}

/*
F は 2 変数の分散表現多項式.
<<0,0>> (定数項) の係数 = 1 となる関係式を返す. 
定数項以外の係数 = 0 となる関係式を返す. 
e.g.
[2794] T0;
(((u001-u002)*a+(-u001+u002)*b)*x+(-u001+u002)*a+(u001-u002)*b)*<<1,0>>+((u001-v002)*x+(-u002+v001)*b+(u002-v001)*bb)*<<0,0>>

[2817] fctr((((u001-u002)*a+(-u001+u002)*b)*x+(-u001+u002)*a+(u001-u002)*b));
[[1,1],[u001-u002,1],[a-b,1],[x-1,1]]
[2819] fctr(+((u001-v002)*x+(-u002+v001)*b+(u002-v001)*bb));
[[1,1],[(u001-v002)*x+(-u002+v001)*b+(u002-v001)*bb,1]]

[2795] build_eq(T0);
[u002-v001-1,u001-v002,u001-u002,u001-u002]
*/
def build_eq(F) {
  Clist=[];
  while (F != 0) {
    C=dp_hc(F); Exp=dp_ht(F);
    C=dp_ptod(C,[x,y]);
    while (C != 0) {
      if ((dp_ht(C) != <<0,0>>) || (Exp != <<0,0>>)) {
	Clist = append(get_uv_0factors(dp_hc(C)),Clist);
	// print([dp_ht(C), Clist]);
      }else{
	Clist = append(get_uv_1factors(dp_hc(C)),Clist);
	// print([dp_ht(C), Clist]);
      }
      C = dp_rest(C);
    }
    F = dp_rest(F);
  }
  return Clist;
}

//T0=(u001-u002)*(x-1)*(a-b)*<<1,0>>+(u001-v002)*x+(bb-b)*(u002-v001)*<<0,0>>;
//build_eq(T0);

/*
  F にあまりを入れる.
e.g. 
[2820] get_uv_rules(T0);
Eq:
[u002-v001-1,u001-v002,u001-u002,u001-u002]
1.nd_gb done.
...
Ans of poly_solve_linear = [[u002,u001],[v001,u001-1],[v002,u001]]
[[[u002,u001],[v001,u001-1],[v002,u001]],[[u001,0],[u003,0],[u004,0],[v003,0],[v004,0]]]
*/
def get_uv_rules(F) {
  UVList=append(NT_UL,NT_VL);
  Eq=build_eq(F);
  // print("Eq:"); print(Eq);
  S=poly_solve_linear(Eq,UVList);
  // printf("Ans of poly_solve_linear = %a\n",S);
  V=[];
  for (I=0; I<length(S); I++) {
    V=cons(S[I][0],V);
  }
  Z = base_set_minus(UVList,V);
  Rule2=assoc(Z,vtol(newvect(length(Z))));
  return [S,Rule2];
}

/*
TR=get_uv_rules(T0)$
T0_1=base_replace(T0,TR[1])$
T0_2=base_replace(T0_1,TR[0])$
T0_3=base_replace(T0_2,TR[1])$
*/

/* 
u, v ありで H B = 0 mod I となるように u, v を定める. 
1. H B mod I を計算し R とする. 
2. get_uv_rules(R) で u, v の Rule を生成. 
3. H, B に Rule を適用し, 昇降作用素を得る. 
*/

/***************************************************************/

/* VL[0] = x, VL[1] = dx     */
/* e.g. gauss(a,b,c,[x,dx]); */
def gauss(A, B, C, VL)
{
	X = VL[0];
	DX = VL[1];
	return X*(1-X)*DX^2+(C-(A+B+1)*X)*DX-A*B;
}

//  mt_mm/rest2.r, f2pq();
//  import("mt_mm.rr"); map(dp_dtop,mt_mm.f2pq(2,1),[x,y,dx,dy]);
def appellF2(Param) {
  F=[(-x^2+x)*dx^2+(-y*x*dy+(-a_00-b_02-1)*x+c_01)*dx-b_02*y*dy-b_02*a_00,
     (-y*x*dy-b_12*x)*dx+(-y^2+y)*dy^2+((-a_00-b_12-1)*y+c_11)*dy-b_12*a_00];
  Rule=assoc([a_00,b_02,b_12,c_01,c_11],Param);
  return [base_replace(F,Rule),[x,y]];
}

def dmult2(F,G){
  N=deg(nm(F),dx);
  M=deg(nm(F),dy);
  A=0;
  for(K=0;K<=N;K++){
    for (J=0; J<=M; J++) {
      A=A+(1/(fac(K)*fac(J)))*diff2(diff2(F,dx,K),dy,J)*diff2(diff2(G,x,K),y,J);
    }
  }
  return red(A);
}

def diff2(F,G,K){
  for(I=0;I<K;I++){
    F=diff(F,G);
  }
  return F;
}

def diff2xy(F,II,JJ){
  F=diff2(F,x,II);
  F=diff2(F,y,JJ);
  return F;
}

def test1() {
  A=x*y^2*dx^2+(x-y-1)^2*dx*dy+(x+y)^3*dy;
  B=A+(x-y-2)^3*dy^2+(x-y)^3;
  F=poly_dmul(A,B,[x,y]);
  F2=dmult2(A,B);
  return F-F2;
}
//test1();

def test2() {
  Q=q00(x,y)+q10(x,y)*dx+q01(x,y)*dy;
  return dmult2(dx,Q);
}
//test2();

def append_n(L) {
  Ans=[];
  for (I=0; I<length(L); I++) {
    Ans=append(Ans,L[I]);
  }
  return Ans;
}

/*************************************************************************
func_v_rule の出力
$ ./a q00 1
[ [[q00(x,y),q00],[q00{1,0}(x,y),q00_1_0],[q00{0,1}(x,y),q00_0_1],[dummy_func,dummy_v]], 
  [[q00,q00(x,y)],[q00_1_0,q00{1,0}(x,y)],[q00_0_1,q00{0,1}(x,y)],[dummy_func,dummy_v]], 
  [q00,q00_1_0,q00_0_1,dummy_v], 
  [[q00,FFF],[q00_1_0,diff2xy(FFF,1,0)],[q00_0_1,diff2xy(FFF,0,1)],[dummy_func,dummy_v]]];

$ ./a q00 2
[ [[q00(x,y),q00],[q00{1,0}(x,y),q00_1_0],[q00{0,1}(x,y),q00_0_1],[q00{2,0}(x,y),q00_2_0],[q00{1,1}(x,y),q00_1_1],[q00{0,2}(x,y),q00_0_2],[dummy_func,dummy_v]], 
  [[q00,q00(x,y)],[q00_1_0,q00{1,0}(x,y)],[q00_0_1,q00{0,1}(x,y)],[q00_2_0,q00{2,0}(x,y)],[q00_1_1,q00{1,1}(x,y)],[q00_0_2,q00{0,2}(x,y)],[dummy_func,dummy_v]], 
  [q00,q00_1_0,q00_0_1,q00_2_0,q00_1_1,q00_0_2,dummy_v], 
  [[q00,FFF],[q00_1_0,diff2xy(FFF,1,0)],[q00_0_1,diff2xy(FFF,0,1)],[q00_2_0,diff2xy(FFF,2,0)],[q00_1_1,diff2xy(FFF,1,1)],[q00_0_2,diff2xy(FFF,0,2)],[dummy_func,dummy_v]]];
*************************************************************************/

/* 2 変数関数を表す変数 q00{1,2}(x,y) について, 
   関数名 q00, 階数 [1,2], 変換後の変数 q00_1_2 を返す */
def func_d2(Var)
{
	Str = rtostr(Var);
	LB = str_chr(Str, 0, "{");
	RB = str_chr(Str, 0, "}");
	LBB = str_chr(Str, 0, "(");
	RBB = str_chr(Str, 0, ")");
	if (LB == -1) {
		/* q00(x,y) の場合 (微分の階数が 0 の場合)*/
		Name = sub_str(Str, 0, LBB - 1); 	
		return [Name, [0,0], strtov(Name)];
	} else {
		Name = sub_str(Str, 0, LB - 1);
		Der = "[" + sub_str(Str, LB+1, RB-1) + "]";	
		Der = eval_str(Der);
		NVar = strtov(sprintf("%a_%a_%a", Name, Der[0], Der[1]));
		return [Name, Der, NVar];
	}
}

def test_func_d2()
{
	function f00(x,y);
	print(func_d2(f00(x,y)));
	print(func_d2(diff(f00(x,y), x)));
	print(func_d2(diff(f00(x,y), y)));
	print(func_d2(diff2xy(f00(x,y), 2,3)));
}

/* compatible with func_v_rule2 */
def my_func_v_rule2(Sym, Deg, FFF)
{
	Rule1 = [];
	Rule2 = [];
	NVL = [];
	Rule3 = [];
	for (K = 0; K <= Deg; K++) {
		for (I = K; I >= 0; I--) {
			J = K - I;
			T = diff2xy(Sym, I, J);
			L = func_d2(T);
			// print([I, J, T, L]);
			NewVar = L[2];
			Ord = L[1];
			Rule1 = cons([T, NewVar], Rule1);
			Rule2 = cons([NewVar, T], Rule2);
			NVL = cons(NewVar, NVL);
			Rule3 = cons([NewVar, diff2xy(FFF, Ord[0], Ord[1])], Rule3);
		}
	}
	return [reverse(Rule1), reverse(Rule2), reverse(NVL), reverse(Rule3)];
}

def test_my_func_v_rule2()
{
	return my_func_v_rule2(q00(x,y), 2, x*y);
}

def appell_f1()
{
	//P1 = dmult2(x*dx, x*dx+y*dy+c-1) - x * dmult2(x*dx+y*dy+a, x*dx+b);
	//P2 = dmult2(y*dy, x*dx+y*dy+c-1) - y * dmult2(x*dx+y*dy+a, y*dy+bb);
	///* for holonomicity */
	//P3 = x*y*((x-y)*dx*dy - bb*dx + b*dy);

	P1 = dmult2(dx, x*dx+y*dy+c-1) - dmult2(x*dx+y*dy+a, x*dx+b);
	P2 = dmult2(dy, x*dx+y*dy+c-1) - dmult2(x*dx+y*dy+a, y*dy+bb);
	/* for holonomicity */
	P3 = (x-y)*dx*dy - bb*dx + b*dy;
	return [P1, P2, P3];
}

def appell_f2()
{
	P1 = dmult2(dx, x*dx+c-1) - dmult2(x*dx+y*dy+a, x*dx+b);	
	P2 = dmult2(dy, y*dy+cc-1) - dmult2(x*dx+y*dy+a, y*dy+bb);	
	if (type(getopt(param)) != -1) {
		P = [a,b,bb,c,cc];
		Param = getopt(param);
		Rule = assoc(P, Param);
		P1 = base_replace(P1, Rule);
		P2 = base_replace(P2, Rule);
	}
	return [P1, P2];
}

def my_base_ith(L, I)
{
	return L[I];
}

/* D/I(Param1) \cong D/I(Param2) となる上昇作用素, 下降作用素 */
/* 同型となるときのパラメータの条件を計算 */
def cont_op(Param1, Param2)
{
	U = getopt(u);
	T = contiguity2(Param1, Param2);
	P = to_op(T[0]);
	P = red(P);
	PNM = nm(P);
	PDN = dn(P);
	if (type(U) != -1) {
		/* option u = [[u***, Number],...] で u に値を代入 */
		PNM = base_replace(PNM, U);	
		PDN = base_replace(PDN, U);	
	}
	return [PNM, PDN];
}

def cont_op_(Param1, Param2)
{
	U = getopt(u);
	T = contiguity2_(Param1, Param2);
	P = to_op(T[0]);
	P = red(P);
	PNM = nm(P);
	PDN = dn(P);
	if (type(U) != -1) {
		/* option u = [[u***, Number],...] で u に値を代入 */
		PNM = base_replace(PNM, U);	
		PDN = base_replace(PDN, U);	
	}
	return [PNM, PDN];
}

def test_cont_op()
{
	/* Appell F2, c == cc の場合 */
	Param1 = [a,b,bb,c+1,c+1];
	Param2 = [a,b,bb,c,c];
	U = [[u118,0],[u119,0],[u115,0],[u116,1]];
	return cont_op(Param1, Param2|u=U);
}

def test_cont_op2()
{
	/* Appell F2, c == cc の場合 */
	Param1 = [a,b,bb,c-1,c-1];
	Param2 = [a,b,bb,c,c];
	U = [[u118,0],[u119,0],[u026,0],[u115,1]];
	return cont_op(Param1, Param2|u=U);
}

def coefs(P, VL)
{
	DP = dp_ptod(P, VL);
	C = [];
	M = [];
	while (DP != 0) {
		C = cons(dp_hc(DP), C);
		M = cons(dp_ht(DP), M);
		DP = dp_rest(DP);
	}
	L = [reverse(C), reverse(M)];
	return L;
}

def to_op(L)
{
	return L[0] + L[1]*dx + L[2]*dy + L[3]*dy^2 + L[4]*dx*dy;
}

/* Var1 = u001, Var2 = v ---> v001 */
def change_var_name(Var1, Var2)
{
	S1 = rtostr(Var1);
	S2 = rtostr(Var2) + sub_str(S1, 1, str_len(S1));	
	return strtov(S2);
}

/*
2 変数に限定
e.g.
Base = [1,dx,dy,dy^2,dx*dy]
Deg = 3
  Sol=[u001+u002*x+u003*y+u004*x^2+u005*x*y+u006*y^2
       +u007*x^3+u008*x^2*y+u009*x*y^2+u0010*y^3,
       u101+u102*x+u103*y+u104*x^2+u105*x*y+u106*y^2
       +u107*x^3+u108*x^2*y+u109*x*y^2+u1010*y^3,
       u011+u012*x+u013*y+u014*x^2+u015*x*y+u016*y^2
       +u017*x^3+u018*x^2*y+u019*x*y^2+u0110*y^3,
       u021+u022*x+u023*y+u024*x^2+u025*x*y+u026*y^2
       +u027*x^3+u028*x^2*y+u029*x*y^2+u0210*y^3,
       u111+u112*x+u113*y+u114*x^2+u115*x*y+u116*y^2
       +u117*x^3+u118*x^2*y+u119*x*y^2+u1110*y^3
      ];
  Sol[0]+Sol[1]*dx+Sol[2]*dy+Sol[3]*dy^2+Sol[4]*dx*dy
*/
def gen_sol(Base, Deg)
{
	Sol = [];
	while (Base != []) {
		T = 0;
		B = car(Base);
		Count = 1;
		for (K = 0; K <= Deg; K++) {
			for (I = 0; I <= K; I++) {
				J = K - I;
				T += gen_u(B, Count) * x^J * y^I;
				Count++;
			}
		}
		Base = cdr(Base);
		Sol = cons(T, Sol);
	}
	return reverse(Sol);
}

def test_gen_sol()
{
	return gen_sol([1,dx,dy,dy^2,dx*dy], 3);
}

/* gen_u(dx*dy^2, 5) ---> u125 */
def gen_u(DX, Count)
{
	E1 = deg(DX, dx);
	E2 = deg(DX, dy);
	return strtov("u" + rtostr(E1) + rtostr(E2) + rtostr(Count));
}

ord(append([dx,dy], ord()))$
